# Copy this file to `.env` and fill in your own values:
#   cp .env.example .env

# Connection string Prisma uses to reach your PostgreSQL database.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/student_store_exemplar"

# Port the Express server listens on.
PORT=3000

# Secret used to sign JWTs for the auth endpoints.
SECRET_KEY="secret_dev"
